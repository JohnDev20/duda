{
  "expo": {
    "name": "DUDA",
    "slug": "duda-leitor",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "duda",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "primaryColor": "#FF1493",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.duda.leitor",
      "infoPlist": {
        "NSDocumentsFolderUsageDescription": "Salvar PDFs na pasta DUDA",
        "NSPhotoLibraryUsageDescription": "Importar capas de livros"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#FF1493"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.duda.leitor",
      "permissions": [
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-document-picker",
      "expo-file-system",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FF1493"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
